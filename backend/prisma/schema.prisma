// Skills Extraction System

// Master database of all skills
model Skill {
  id                String        @id @default(uuid())
  name              String        @unique // Nom de la compÃ©tence (ex: "BSP", "Service Ã  la clientÃ¨le")
  category          SkillCategory
  description       String?       @db.Text // Description dÃ©taillÃ©e
  keywords          String[] // Mots-clÃ©s pour extraction (ex: ["bsp", "bureau de la sÃ©curitÃ© privÃ©e"])
  isActive          Boolean       @default(true) // Permet de dÃ©sactiver des compÃ©tences obsolÃ¨tes
  isSecurityRelated Boolean       @default(false) // CompÃ©tence liÃ©e aux agents de sÃ©curitÃ© (core business)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  candidateSkills CandidateSkill[]
  prospectSkills  ProspectSkill[]

  @@index([category])
  @@index([name])
  @@index([isActive])
  @@index([isSecurityRelated])
  @@map("skills")
}

// Many-to-many relationship between Candidate and Skill
model CandidateSkill {
  id          String      @id @default(uuid())
  candidateId String
  skillId     String
  level       SkillLevel  @default(UNKNOWN)
  source      SkillSource @default(MANUAL_ENTRY)

  // Contexte d'extraction
  yearsExperience Int? // Nombre d'annÃ©es d'expÃ©rience (si dÃ©tectÃ©)
  extractedText   String? @db.Text // Texte exact extrait du CV
  confidence      Float? // Score de confiance de l'IA (0-1)

  // Validation humaine
  isVerified    Boolean   @default(false)
  verifiedBy    String? // ID de l'utilisateur qui a vÃ©rifiÃ©
  verifiedAt    DateTime?
  rejectionNote String?   @db.Text // Note si la compÃ©tence est rejetÃ©e

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skillId], references: [id])

  @@unique([candidateId, skillId]) // Un candidat ne peut avoir la mÃªme compÃ©tence qu'une fois
  @@index([candidateId])
  @@index([skillId])
  @@index([level])
  @@index([source])
  @@index([isVerified])
  @@map("candidate_skills")
}

// Skills for Prospects (NOT converted to candidates yet)
model ProspectSkill {
  id         String      @id @default(uuid())
  prospectId String
  skillId    String
  level      SkillLevel  @default(UNKNOWN)
  source     SkillSource @default(MANUAL_ENTRY)

  // Contexte d'extraction
  yearsExperience Int? // Nombre d'années d'expérience (si détecté)
  extractedText   String? @db.Text // Texte exact extrait du CV
  confidence      Float? // Score de confiance de l'IA (0-1)

  // Validation humaine
  isVerified    Boolean   @default(false)
  verifiedBy    String? // ID de l'utilisateur qui a vérifié
  verifiedAt    DateTime?
  rejectionNote String?   @db.Text // Note si la compétence est rejetée

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  prospect ProspectCandidate @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  skill    Skill             @relation(fields: [skillId], references: [id])

  @@unique([prospectId, skillId]) // Un prospect ne peut avoir la même compétence qu'une fois
  @@index([prospectId])
  @@index([skillId])
  @@index([level])
  @@index([source])
  @@index([isVerified])
  @@map("prospect_skills")
}

// Audit trail for CV extraction
model CvExtractionLog {
  id          String @id @default(uuid())
  candidateId String

  // Extraction details
  extractionMethod String // "REGEX", "OPENAI", "CLAUDE"
  skillsFound      Int    @default(0)
  processingTimeMs Int? // Temps de traitement en ms

  // AI details (if applicable)
  aiModel          String? // "gpt-4", "claude-3-opus", etc.
  promptTokens     Int? // Tokens utilisÃ©s dans le prompt
  completionTokens Int? // Tokens utilisÃ©s dans la rÃ©ponse
  totalCost        Float? // CoÃ»t estimÃ© en USD

  // Results
  success      Boolean @default(true)
  errorMessage String? @db.Text
  rawResponse  String? @db.Text // RÃ©ponse brute de l'IA (pour debugging)

  createdAt DateTime @default(now())

  @@index([candidateId])
  @@index([extractionMethod])
  @@index([success])
  @@index([createdAt])
  @@map("cv_extraction_logs")
}

// ===========================================================================
// EMPLOYÉS
// Troisième étage du cycle de vie : Candidat Potentiel -> Candidat -> Employé.
// Un employé vit UNIQUEMENT ici : il ne doit jamais réapparaître dans
// Candidats ni Candidats Potentiels (l'Employé gagne toujours).
// ===========================================================================

enum EmployeeStatus {
  ACTIF
  INACTIF
}

model Employee {
  id String @id @default(uuid())

  // Informations personnelles
  firstName  String
  lastName   String
  email      String?
  phone      String
  address    String?
  city       String?
  province   String  @default("QC")
  postalCode String?

  // Emploi
  status         EmployeeStatus @default(ACTIF)
  hireDate       DateTime? // Date d'embauche
  employeeNumber String? // Matricule (optionnel)
  position       String? // Poste / titre
  assignment     String? // Mandat / site (ex: Magellan Brossard)

  // Certifications clés (reportées du candidat)
  hasBSP        Boolean   @default(false)
  bspNumber     String?
  bspExpiryDate DateTime?
  hasVehicle    Boolean   @default(false)

  // CV / documents (conservés depuis la fiche candidat)
  cvUrl            String?
  cvStoragePath    String?
  videoUrl         String?
  videoStoragePath String?

  notes String? @db.Text

  // Lien vers la fiche candidat d'origine (traçabilité)
  convertedFromCandidateId String?

  // Metadata
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([isDeleted])
  @@index([lastName])
  @@index([city])
  @@index([convertedFromCandidateId])
  @@map("employees")
}

// ===========================================================================
// UNIFORMES — Prêt / retour d'uniformes & équipements aux agents.
// Reproduit les 2 formulaires papier XGuard (Prêt / Retour d'uniforme).
// Le lien aux employés se fait par employeeId (String) SANS relation/FK Prisma
// — n'altère pas la table employees ; les jointures sont explicites dans les
// controllers (même esprit que convertedFromCandidateId).
// Le registre uniform_stock_movements est la source de vérité auditable du
// stock ; UniformVariant.quantityOnHand est un cache muté UNIQUEMENT dans la
// même transaction qu'un mouvement.
// ===========================================================================

enum UniformDivision {
  SECURITE
  SIGNALISATION
}

enum UniformPieceType {
  UNIFORME
  EQUIPEMENT
}

enum UniformMovementType {
  IN // réappro / retour réutilisable (delta +)
  OUT // remise à un agent (delta -)
  ADJUST // correction d'inventaire (quantity signé)
  LOST // perdu (delta -, sortie définitive)
  DAMAGED // endommagé / poubelle directe au retour (delta -, sortie définitive)
  // === V2 — Cycle de lavage ===
  WASH_IN // pièce vers lot de lavage (delta - sur quantityOnHand)
  WASH_OUT_GOOD // pièce sortie du lot vers stock (delta +)
  WASH_OUT_DAMAGED // pièce sortie du lot vers poubelle (delta 0, audit seul)
  DISPOSAL // sortie définitive explicite (delta 0, audit seul)
  TRANSFER // déplacement entre emplacements (quantity signé ; total inchangé sur la paire)
}

// Emplacements physiques du stock. BACK_OFFICE = entrepôt principal (gros stock) ;
// FRONT_OFFICE = comptoir de remise (petit stock). Un transfert déplace des pièces
// de l'un à l'autre sans changer la quantité totale.
enum UniformStockLocation {
  BACK_OFFICE
  FRONT_OFFICE
}

enum UniformItemCondition {
  GOOD
  DAMAGED
  LOST
  NOT_RETURNED // non retourné à la fin d'emploi (clause dernière paie)
}

enum UniformIssuanceStatus {
  DRAFT
  ISSUED
  PARTIALLY_RETURNED
  RETURNED
  CLOSED_TERMINATION
  CANCELLED
}

enum UniformSignatureStatus {
  PENDING
  SENT
  SIGNED
  SKIPPED
}

enum UniformSignatureMethod {
  REMOTE_SMS
  COUNTER
}

// ===========================================================================
// V2 — Cycle de lavage & rebut
// ===========================================================================

enum WashBatchStatus {
  CREATED // pièces collectées, lot en préparation
  SENT_TO_LAUNDRY // expédié au fournisseur
  RETURNED_FROM_LAUNDRY // revenu, en attente d'inspection
  INSPECTED // inspection finalisée (terminal)
  CANCELLED // lot annulé (pièces réinjectées en stock)
}

// ===========================================================================
// V2 — Notifications (multi-canal : in-app + email + sms)
// ===========================================================================

enum NotificationType {
  // Cycle de vie pièce
  UNIFORM_RETURN_DAMAGED
  UNIFORM_WASH_BATCH_CREATED
  UNIFORM_WASH_BATCH_SENT
  UNIFORM_WASH_BATCH_RETURNED
  UNIFORM_WASH_BATCH_INSPECTED_DAMAGED
  UNIFORM_WASH_BATCH_STAGNANT
  // Date butoir & paie
  UNIFORM_RETURN_DUE_SOON
  UNIFORM_RETURN_OVERDUE
  UNIFORM_TERMINATION_CLOSED
  UNIFORM_SETTLEMENT_RECORDED
  UNIFORM_DEBT_AGING
  // Stock & inventaire
  UNIFORM_LOW_STOCK
  UNIFORM_STOCK_ZERO
  UNIFORM_LEDGER_DRIFT
  // Signature / workflow
  UNIFORM_SIGNATURE_EXPIRING
  UNIFORM_SIGNATURE_EXPIRED
  UNIFORM_EMPLOYER_SIGN_PENDING
  // Anomalies
  UNIFORM_BARCODE_UNKNOWN
  UNIFORM_INACTIVE_VARIANT_HAS_STOCK
  UNIFORM_DUPLICATE_ACTIVE_ISSUANCE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ // pour IN_APP seulement
}

model UniformItem {
  id                     String           @id @default(uuid())
  division               UniformDivision
  type                   UniformPieceType @default(UNIFORME)
  name                   String
  isOneSize              Boolean          @default(false) // "Taille unique"
  defaultReplacementCost Decimal          @default(0) @db.Decimal(10, 2)
  imageStoragePath       String? // photo du morceau (clé R2)
  imageFit               String? // affichage photo : 'cover' (remplir) | 'contain' (entière)
  sortOrder              Int              @default(0)
  isActive               Boolean          @default(true)
  createdById            String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  variants UniformVariant[]

  @@unique([division, name])
  @@index([division])
  @@index([type])
  @@index([isActive])
  @@map("uniform_items")
}

model UniformVariant {
  id               String   @id @default(uuid())
  itemId           String
  size             String   @default("Unique") // grandeur libre ; "Unique" si one-size/équipement
  sku              String?
  emplacement      String? // localisation physique (ex. "B4", "A1-A2", "Étagère")
  barcode          String   @unique // valeur Code128 générée par le système
  replacementCost  Decimal  @default(0) @db.Decimal(10, 2)
  quantityOnHand   Int      @default(0) // cache du TOTAL (= Σ emplacements) — voir registre des mouvements
  reorderThreshold Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  item            UniformItem            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  movements       UniformStockMovement[]
  issuanceLines   UniformIssuanceLine[]
  returnLines     UniformReturnLine[]
  washBatchItems  UniformWashBatchItem[]
  stockByLocation UniformVariantStock[]

  @@unique([itemId, size])
  @@index([itemId])
  @@index([barcode])
  @@index([isActive])
  @@map("uniform_variants")
}

// Stock par emplacement physique. Le total (UniformVariant.quantityOnHand) reste
// le cache global ; cette table ventile ce total entre BACK_OFFICE et FRONT_OFFICE.
// Réconciliation : quantityOnHand(loc) == Σ(mouvements de cette variante & loc).
model UniformVariantStock {
  id             String               @id @default(uuid())
  variantId      String
  location       UniformStockLocation
  quantityOnHand Int                  @default(0)
  updatedAt      DateTime             @updatedAt

  variant UniformVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, location])
  @@index([variantId])
  @@map("uniform_variant_stock")
}

model UniformStockMovement {
  id          String               @id @default(uuid())
  variantId   String
  type        UniformMovementType
  quantity    Int // delta signé sur le stock
  location    UniformStockLocation @default(BACK_OFFICE) // emplacement affecté par ce mouvement
  reason      String?              @db.Text
  issuanceId  String? // back-ref si généré par une remise
  returnId    String? // back-ref si généré par un retour
  createdById String?
  createdAt   DateTime             @default(now())

  variant UniformVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([type])
  @@index([location])
  @@index([issuanceId])
  @@index([returnId])
  @@index([createdAt])
  @@map("uniform_stock_movements")
}

model UniformIssuance {
  id             String                @id @default(uuid())
  employeeId     String // lien lâche vers employees.id (pas de FK)
  division       UniformDivision
  status         UniformIssuanceStatus @default(DRAFT)
  notes          String?               @db.Text
  issuedAt       DateTime? // remise physique = décrément du stock
  dueReturnAt    DateTime?
  totalLoanCost  Decimal               @default(0) @db.Decimal(10, 2) // "Coût total du prêt"
  sourceLocation UniformStockLocation  @default(FRONT_OFFICE) // d'où le stock est décrémenté

  // Consentements du formulaire
  payrollConsentAccepted       Boolean @default(false) // prélèvement dernière paie
  uniformPolicyConsentAccepted Boolean @default(false) // respect du port (Sécurité)
  fitAttested                  Boolean @default(false) // a essayé, taille adéquate

  // Signatures
  employeeSignatureStoragePath String?
  employerSignatureStoragePath String?
  signatureStatus              UniformSignatureStatus  @default(PENDING)
  signatureMethod              UniformSignatureMethod?
  signedAt                     DateTime?
  signedByName                 String?

  // Lien public de signature (SMS)
  signToken          String?   @unique
  signTokenExpiresAt DateTime?
  smsSentAt          DateTime?
  ghlMessageId       String?

  formPdfStoragePath String? // PDF du formulaire archivé (R2)
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lines   UniformIssuanceLine[]
  returns UniformReturn[]

  @@index([employeeId])
  @@index([division])
  @@index([status])
  @@index([signToken])
  @@index([dueReturnAt])
  @@index([createdAt])
  @@map("uniform_issuances")
}

model UniformIssuanceLine {
  id               String                @id @default(uuid())
  issuanceId       String
  variantId        String? // null si ligne "Autre"
  customItemName   String? // libellé libre pour "Autre"
  quantity         Int
  unitCostSnapshot Decimal               @default(0) @db.Decimal(10, 2)
  sourceLocation   UniformStockLocation? // d'où CETTE pièce sort (null = hérite de issuance.sourceLocation)

  issuance UniformIssuance @relation(fields: [issuanceId], references: [id], onDelete: Cascade)
  variant  UniformVariant? @relation(fields: [variantId], references: [id])

  @@index([issuanceId])
  @@index([variantId])
  @@map("uniform_issuance_lines")
}

model UniformReturn {
  id         String                @id @default(uuid())
  issuanceId String
  employeeId String // dénormalisé pour la fiche
  status     UniformIssuanceStatus @default(DRAFT)
  notes      String?               @db.Text
  returnedAt DateTime?

  employeeSignatureStoragePath String?
  employerSignatureStoragePath String?
  signatureStatus              UniformSignatureStatus  @default(PENDING)
  signatureMethod              UniformSignatureMethod?
  signedAt                     DateTime?
  signedByName                 String?

  signToken          String?   @unique
  signTokenExpiresAt DateTime?
  smsSentAt          DateTime?
  ghlMessageId       String?

  formPdfStoragePath String?
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  issuance UniformIssuance     @relation(fields: [issuanceId], references: [id], onDelete: Cascade)
  lines    UniformReturnLine[]

  @@index([issuanceId])
  @@index([employeeId])
  @@index([signToken])
  @@index([createdAt])
  @@map("uniform_returns")
}

model UniformReturnLine {
  id                  String               @id @default(uuid())
  returnId            String
  variantId           String?
  customItemName      String?
  quantity            Int
  condition           UniformItemCondition @default(GOOD)
  unitReplacementCost Decimal              @default(0) @db.Decimal(10, 2) // snapshot pour figer la dette

  return         UniformReturn          @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant        UniformVariant?        @relation(fields: [variantId], references: [id])
  washBatchItems UniformWashBatchItem[]

  @@index([returnId])
  @@index([variantId])
  @@index([condition])
  @@map("uniform_return_lines")
}

model UniformDebtSettlement {
  id          String   @id @default(uuid())
  employeeId  String
  amount      Decimal  @db.Decimal(10, 2)
  method      String? // "PAYÉ" | "RETENUE PAIE" | "RADIÉ"
  notes       String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@map("uniform_debt_settlements")
}

// ===========================================================================
// V2 — Lots de lavage
// ===========================================================================

model UniformWashBatch {
  id            String          @id @default(uuid())
  status        WashBatchStatus @default(CREATED)
  vendor        String? // fournisseur de lavage (texte libre)
  notes         String?         @db.Text
  sentAt        DateTime?
  returnedAt    DateTime?
  inspectedAt   DateTime?
  createdById   String?
  inspectedById String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items UniformWashBatchItem[]

  @@index([status])
  @@index([createdAt])
  @@map("uniform_wash_batches")
}

model UniformWashBatchItem {
  id                String                @id @default(uuid())
  batchId           String
  variantId         String
  quantity          Int                   @default(1) // qty=1 pour granularité par pièce
  returnLineId      String? // provenance (UniformReturnLine source)
  postWashCondition UniformItemCondition? // null jusqu'à inspection
  notes             String?               @db.Text
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  batch      UniformWashBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  variant    UniformVariant     @relation(fields: [variantId], references: [id])
  returnLine UniformReturnLine? @relation(fields: [returnLineId], references: [id])

  @@index([batchId])
  @@index([variantId])
  @@index([returnLineId])
  @@map("uniform_wash_batch_items")
}

// ===========================================================================
// V2 — Notifications (in-app + email)
// ===========================================================================

model Notification {
  id             String              @id @default(uuid())
  userId         String? // destinataire IN_APP (null = canal email/sms standalone)
  type           NotificationType
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  recipientEmail String? // pour channel=EMAIL (ex: rh@xguard.ca)
  recipientPhone String? // pour channel=SMS
  title          String
  message        String              @db.Text
  link           String? // URL frontend à ouvrir au clic
  payload        Json? // données structurées (ex: { issuanceId, employeeId })
  dedupKey       String?             @unique // idempotence (ex: "due-soon-{issuanceId}")
  scheduledFor   DateTime? // null = immédiat ; sinon worker ramasse après
  sentAt         DateTime?
  failedReason   String?             @db.Text
  attempts       Int                 @default(0)
  readAt         DateTime? // IN_APP uniquement
  createdAt      DateTime            @default(now())

  @@index([userId, readAt])
  @@index([status, scheduledFor])
  @@index([channel, status])
  @@index([createdAt])
  @@map("notifications")
}

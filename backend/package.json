{
  "name": "talentsecure-backend",
  "version": "1.0.0",
  "description": "TalentSecure Backend API - XGUARD Security",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && echo 'Build completed successfully'",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "backfill:geocode": "ts-node src/scripts/backfillProspectGeocodes.ts",
    "backfill:geocode-candidates": "ts-node src/scripts/backfillCandidateGeocodes.ts",
    "backfill:experience-months": "ts-node src/scripts/backfillExperienceMonths.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --testPathPattern='(env|rate-limit|token-util|skill-normalization|ai-extraction)\\.test\\.ts$'",
    "lint": "eslint 'src/**/*.ts' --report-unused-disable-directives",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "test:db:push": "prisma db push --skip-generate --force-reset"
  },
  "keywords": [
    "talentsecure",
    "recruitment",
    "security"
  ],
  "author": "XGUARD Security",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.932.0",
    "@aws-sdk/s3-request-presigner": "^3.932.0",
    "@google-cloud/storage": "^7.17.3",
    "@prisma/client": "^5.7.0",
    "@sentry/node": "^8.55.2",
    "@types/archiver": "^8.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/uuid": "^9.0.8",
    "archiver": "^8.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.10.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.5",
    "googleapis": "^166.0.0",
    "helmet": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.14.0",
    "redis": "^4.6.12",
    "sharp": "^0.33.2",
    "stripe": "^22.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xss": "^1.0.15",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
